# ========================================
# LLM API 配置
# ========================================

# SiliconFlow配置（推荐，国内访问快）
SILICONFLOW_API_KEY=your-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# OpenAI配置（备选）
# OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ========================================
# Hugging Face 镜像配置
# ========================================
HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# ========================================
# RAG Fusion 配置（新增）
# ========================================

# 是否启用RAG Fusion（true/false）
ENABLE_RAG_FUSION=true

# 生成查询数量（3-10，推荐5）
# 越多召回越全，但越慢
RAG_FUSION_NUM_QUERIES=5

# 每个查询召回文档数（5-10，推荐8）
RAG_FUSION_DOCS_PER_QUERY=8

# 是否启用精排（true/false）
# 启用会更准确但更慢
RAG_FUSION_ENABLE_RERANKING=false

# ========================================
# Agent 配置
# ========================================

# 使用哪个Agent（0=Standard, 1=Fast）
USE_FAST_AGENT=1

# ========================================
# 其他配置
# ========================================

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
