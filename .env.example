# ========================================
# LLM API 配置
# ========================================

# SiliconFlow配置（推荐，国内访问快）
SILICONFLOW_API_KEY=your-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# OpenAI配置（备选）
# OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ========================================
# Hugging Face 镜像配置
# ========================================
HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# ========================================
# RAG Fusion 配置（新增）
# ========================================

# 是否启用RAG Fusion（true/false）
ENABLE_RAG_FUSION=true

# 生成查询数量（3-10，推荐5）
# 越多召回越全，但越慢
RAG_FUSION_NUM_QUERIES=5

# 每个查询召回文档数（5-10，推荐8）
RAG_FUSION_DOCS_PER_QUERY=8

# 是否启用精排（true/false）
# 启用会更准确但更慢
RAG_FUSION_ENABLE_RERANKING=false

# ========================================
# Agent 配置
# ========================================

# 使用哪个Agent（0=Standard, 1=Fast）
USE_FAST_AGENT=1

# ========================================
# 火山引擎豆包语音 API 配置（替换本地 ASR/TTS）
# ========================================

# 豆包语音 APP ID（控制台 > 豆包语音 > 应用管理，纯数字格式）
VOLC_APP_ID=your-app-id-here

# 豆包语音 Access Token（控制台获取，UUID 格式）
VOLC_ACCESS_TOKEN=your-access-token-here

# TTS 音色（默认温柔女声，可在豆包语音音色库选择）
VOLC_TTS_VOICE=zh_female_shuangkuaisisi_moon_bigtts

# TTS 资源ID（seed-tts-1.0 或 seed-tts-2.0）
VOLC_TTS_RESOURCE=seed-tts-1.0

# 是否启用火山引擎 ASR API（true=云端，false=本地SenseVoice）
USE_ARK_ASR=false

# 是否启用火山引擎 TTS API（true=云端，false=本地ZipVoice）
USE_ARK_TTS=false

# ========================================
# 其他配置
# ========================================

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
